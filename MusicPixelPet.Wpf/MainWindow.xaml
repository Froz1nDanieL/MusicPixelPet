<Window x:Class="MusicPetDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MusicPixelPet.Wpf.Converters"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Music Pixel Pet"
        Width="300"
        Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="{Binding Settings.AlwaysOnTop}"
        Loaded="Window_OnLoaded"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown"
        MouseEnter="Window_OnMouseEnter"
        MouseLeave="Window_OnMouseLeave">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />

        <Style x:Key="CardTextBlock" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="#171717" />
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#171717" />
            <Setter Property="Background" Value="#F4F4F1" />
            <Setter Property="BorderBrush" Value="#D9D9D2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFEFEC" />
                                <Setter Property="BorderBrush" Value="#BEBEB6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconPath" TargetType="Path">
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>
    </Window.Resources>

    <Grid Opacity="{Binding IsReady, Converter={StaticResource BooleanToOpacityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0"
                 Width="192"
                 Padding="10,9,10,10"
                 Background="#F5FAFAF8"
                 PreviewMouseWheel="NowPlayingCard_OnPreviewMouseWheel">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Text="{Binding ActivePlayerLabel}"
                               FontSize="11"
                               Foreground="#757575"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding PlaybackLabel}"
                               HorizontalAlignment="Right"
                               FontSize="11"
                               Foreground="#666666" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,7,0,0"
                           Style="{StaticResource CardTextBlock}"
                           Text="{Binding StatusTitle}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           LineHeight="17"
                           MaxHeight="36"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="2"
                           Margin="0,4,0,0"
                           Text="{Binding StatusSubtitle}"
                           FontSize="11"
                           Foreground="#757575"
                           TextTrimming="CharacterEllipsis" />

                <Grid Grid.Row="3" Margin="0,10,0,0" Height="22">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Bottom"
                                Height="22">
                        <Rectangle Width="5" Height="8" Fill="#242424" RadiusX="2.5" RadiusY="2.5" Margin="0,0,4,0" />
                        <Rectangle Width="5" Height="12" Fill="#242424" RadiusX="2.5" RadiusY="2.5" Margin="0,0,4,0" />
                        <Rectangle Width="5" Height="17" Fill="#242424" RadiusX="2.5" RadiusY="2.5" Margin="0,0,4,0" />
                        <Rectangle Width="5" Height="10" Fill="#242424" RadiusX="2.5" RadiusY="2.5" Margin="0,0,4,0" />
                        <Rectangle Width="5" Height="15" Fill="#242424" RadiusX="2.5" RadiusY="2.5" Margin="0,0,4,0" />
                        <Rectangle Width="5" Height="20" Fill="#242424" RadiusX="2.5" RadiusY="2.5" Margin="0,0,4,0" />
                        <Rectangle Width="5" Height="13" Fill="#242424" RadiusX="2.5" RadiusY="2.5" Margin="0,0,4,0" />
                        <Rectangle Width="5" Height="9" Fill="#242424" RadiusX="2.5" RadiusY="2.5" />
                    </StackPanel>

                    <ProgressBar Width="58"
                                 Height="4"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="{Binding VolumeLevel, Mode=OneWay}"
                                 Foreground="#242424"
                                 Background="#DEDED8"
                                 BorderBrush="{x:Null}" />
                </Grid>
            </Grid>
        </ui:Card>

        <Grid Grid.Row="1"
              Width="170"
              Height="146"
              Cursor="Hand"
              MouseLeftButtonDown="PetSurface_OnMouseLeftButtonDown">
            <Image x:Name="PetImage"
                   Width="128"
                   Height="128"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Stretch="None"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
        </Grid>

        <ui:Card Grid.Row="2"
                 Width="208"
                 Padding="6"
                 Margin="0,0,0,12"
                 Background="#FAFFFFFF"
                 Opacity="{Binding ControlBarVisible, Converter={StaticResource BooleanToOpacityConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:Button Style="{StaticResource IconButton}"
                           Command="{Binding PreviousCommand}"
                           IsEnabled="{Binding Media.CanGoPrevious}"
                           ToolTip="Previous">
                    <Path Style="{StaticResource IconPath}" Data="M 8 7 L 8 17 M 17 7 L 11 12 L 17 17 Z" />
                </ui:Button>

                <ui:Button Style="{StaticResource IconButton}"
                           Margin="6,0,0,0"
                           Command="{Binding PlayPauseCommand}"
                           IsEnabled="{Binding Media.CanPlayPause}"
                           ToolTip="Play/Pause">
                    <Grid>
                        <Path Data="M 9 7 L 17 12 L 9 17 Z">
                            <Path.Style>
                                <Style TargetType="Path" BasedOn="{StaticResource IconPath}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <Path Data="M 9 7 L 9 17 M 15 7 L 15 17">
                            <Path.Style>
                                <Style TargetType="Path" BasedOn="{StaticResource IconPath}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Grid>
                </ui:Button>

                <ui:Button Style="{StaticResource IconButton}"
                           Margin="6,0,0,0"
                           Command="{Binding NextCommand}"
                           IsEnabled="{Binding Media.CanGoNext}"
                           ToolTip="Next">
                    <Path Style="{StaticResource IconPath}" Data="M 16 7 L 16 17 M 7 7 L 13 12 L 7 17 Z" />
                </ui:Button>

                <ui:Button Style="{StaticResource IconButton}"
                           Margin="6,0,0,0"
                           Command="{Binding OpenSettingsCommand}"
                           ToolTip="Settings">
                    <Path Style="{StaticResource IconPath}" Data="M 8 5.5 L 16 5.5 L 20 12 L 16 18.5 L 8 18.5 L 4 12 Z M 12 9.8 A 2.2 2.2 0 1 1 12 14.2 A 2.2 2.2 0 1 1 12 9.8" />
                </ui:Button>
            </StackPanel>
        </ui:Card>
    </Grid>
</Window>
