{
  "appId": "com.musicpixelpet.app",
  "productName": "Music Pixel Pet",
  "directories": {
    "output": "release-tmp"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "extraFiles": [
    {
      "from": "native-helper/MusicPixelPet.Helper/bin/Release/net8.0-windows10.0.19041.0",
      "to": "helper",
      "filter": [
        "MusicPixelPet.Helper.exe",
        "MusicPixelPet.Helper.dll",
        "MusicPixelPet.Helper.runtimeconfig.json",
        "MusicPixelPet.Helper.deps.json",
        "Microsoft.Windows.SDK.NET.dll",
        "WinRT.Runtime.dll"
      ]
    }
  ],
  "win": {
    "target": ["nsis", "portable"],
    "signAndEditExecutable": false
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false,
    "runAfterFinish": false,
    "include": "build/installer.nsh"
  }
}
